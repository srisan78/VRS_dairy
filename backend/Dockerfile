# Step 1: Build Stage
# Using Node 20 to satisfy '@google/genai' and 'vite' requirements
FROM node:20-alpine AS build

WORKDIR /app

# Copy package files first to leverage Docker layer caching
COPY package*.json ./

# Remove any old lock files that might cause "Native Binding" errors 
# and do a clean install
RUN rm -f package-lock.json && npm install

# Copy the rest of your dairy farm source code
COPY . .

# Build the React application
RUN npm run build

# Step 2: Production Stage
# Using Nginx to serve the static files generated by Vite
FROM nginx:alpine

# Copy the build output from the previous stage to Nginx's html folder
# Vite builds into the 'dist' folder by default
COPY --from=build /app/dist /usr/share/nginx/html

# Expose port 80 for the web server
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]